# --- SPIRAM (PSRAM) Configuration (N16R8) ---
CONFIG_SPIRAM=y
CONFIG_SPIRAM_TYPE_ESPPSRAM64=y
CONFIG_SPIRAM_MODE_OCT=y
# Start at 40MHz for stability; if this boots, you can try 80M later
CONFIG_SPIRAM_SPEED_40M=y
CONFIG_SPIRAM_BOOT_INIT=y

# --- Flash Settings (16MB) ---
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHFREQ_40M=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"

# --- Memory Management ---
# Allocations larger than 16KB go to PSRAM
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=32768
# This allows the compiler to put larger static arrays into PSRAM
CONFIG_SPIRAM_ALLOW_BSS_SEG_EXTERNAL_MEMORY=y

# --- System Settings ---
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_MAXIMUM_LEVEL_DEBUG=y

# --- Networking & Security ---
CONFIG_LWIP_LOCAL_HOSTNAME="ashura"
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y

# --- Safety & Watchdog (Industry Standard) ---
# Enable Task Watchdog Timer (TWDT) on startup
CONFIG_ESP_TASK_WDT_INIT=y

# Timeout in seconds. 15s is a safe "Development" middle ground.
CONFIG_ESP_TASK_WDT_TIMEOUT_S=15

# Ensure the Watchdog monitors the Idle Task on BOTH cores.
# This forces you to write "polite" code with vTaskDelay().
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU0=y
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU1=y

# Panic when a watchdog timeout occurs (prints the backtrace/error)
# This is much better for debugging than a silent reboot.
CONFIG_ESP_TASK_WDT_PANIC=y

# --- Networking: WebSocket Client Configuration ---
# Enable the native ESP-WebSocket Client component
CONFIG_ESP_WEBSOCKET_CLIENT=y
# Set the RX/TX data buffer size (4KB) for JSON messages
CONFIG_ESP_WEBSOCKET_CLIENT_BUFFER_SIZE=4096
# Allocate 8KB stack for the WebSocket background task
CONFIG_ESP_WEBSOCKET_CLIENT_TASK_STACK=8192